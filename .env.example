# ════════════════════════════════════════════════
# Investment Assistant — Configuration
# ════════════════════════════════════════════════
# Copy this file to .env and fill in your details.
# NEVER share this file or commit to git.

# ── Trading 212 ──────────────────────────────────
# Get from: Trading 212 App → Settings → API (beta)
T212_API_KEY=your_api_key_here
T212_API_SECRET=your_api_secret_here

# "demo" = paper trading (safe to test), "live" = real money
T212_MODE=demo

# ── Telegram Bot ─────────────────────────────────
# Get TOKEN from: @BotFather on Telegram
# Get CHAT_ID: message your bot then visit:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz
TELEGRAM_CHAT_ID=987654321

# ── Budget Settings ───────────────────────────────
TOTAL_BUDGET=300
MAX_PER_TRADE=30

# ── Confirmation Timeout (seconds) ───────────────
# How long to wait for your YES/NO reply
CONFIRM_TIMEOUT=300
